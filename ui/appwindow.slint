import { LineEdit, CheckBox, Slider } from "std-widgets.slint";

// ─── Data Structures ───────────────────────────────────────────────────────────

export struct ProfileData {
    name: string,
    created: string,
    desktop: string,
    is_remote: bool,
    package_count: int,
    config_count: int,
}

export struct DesktopEnvironmentData {
    name: string,
    is_current: bool,
    session_id: string,
}

export struct BackupItemData {
    name: string,
    path: string,
    enabled: bool,
    category: string,
    size_estimate: string,
}

export struct ConflictFixData {
    name: string,
    description: string,
    enabled: bool,
    category: string,
}

export struct FolderBackupData {
    label: string,
    source_path: string,
    dest_path: string,
    enabled: bool,
}

export struct ScheduledSaveData {
    label: string,
    interval: string,
    enabled: bool,
    last_run: string,
}

// ─── Reusable Components ───────────────────────────────────────────────────────

// Primary action button (orange)
component PrimaryBtn inherits Rectangle {
    in property <string> label;
    in property <bool> enabled-btn: true;
    callback clicked;

    height: 36px;
    background: enabled-btn ? #f97316 : #4a3a28;
    border-radius: 6px;

    btn-touch := TouchArea {
        mouse-cursor: enabled-btn ? pointer : default;
        clicked => {
            if (root.enabled-btn) {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: center;
        Text {
            text: root.label;
            font-size: 13px;
            font-weight: 600;
            color: #ffffff;
            vertical-alignment: center;
        }
    }

    animate background { duration: 100ms; }
}

// Secondary/neutral button (dark grey)
component SecondaryBtn inherits Rectangle {
    in property <string> label;
    callback clicked;

    height: 36px;
    background: btn-touch.has-hover ? #2d333b : #21262d;
    border-radius: 6px;

    btn-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: center;
        Text {
            text: root.label;
            font-size: 13px;
            font-weight: 600;
            color: #c9d1d9;
            vertical-alignment: center;
        }
    }

    animate background { duration: 100ms; }
}

// Small action button (for inline list items)
component SmallBtn inherits Rectangle {
    in property <string> label;
    in property <bool> is-primary: false;
    callback clicked;

    height: 32px;
    background: is-primary
        ? (btn-touch.has-hover ? #e0650f : #f97316)
        : (btn-touch.has-hover ? #2d333b : #21262d);
    border-radius: 6px;

    btn-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: center;
        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 600;
            color: #ffffff;
            vertical-alignment: center;
        }
    }

    animate background { duration: 100ms; }
}

// Pill badge for category labels
component Pill inherits Rectangle {
    in property <string> label;
    in property <color> pill-bg: #21262d;
    in property <color> pill-color: #8b949e;

    height: 22px;
    background: pill-bg;
    border-radius: 11px;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        alignment: center;
        Text {
            text: root.label;
            font-size: 10px;
            font-weight: 700;
            color: root.pill-color;
            vertical-alignment: center;
        }
    }
}

// ─── Main Window ───────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Shapeshifter — Desktop Environment & Profile Manager";
    background: #0d1117;
    preferred-width: 1120px;
    preferred-height: 760px;
    min-width: 900px;
    min-height: 600px;

    // ── Bound properties ────────────────────────────────────────────────────
    in-out property <string>  remote-url;
    in-out property <[ProfileData]> profiles;
    in-out property <[DesktopEnvironmentData]> available-desktops;
    in-out property <string>  status-message: "";
    in-out property <string>  status-type: "info";
    in-out property <[BackupItemData]> backup-items;
    in-out property <[ConflictFixData]> conflict-fixes;
    in-out property <[FolderBackupData]> folder-backups;
    in-out property <[ScheduledSaveData]> scheduled-saves;
    in-out property <string>  current-de;
    in-out property <string>  current-user;
    in-out property <bool>    auto-save-enabled: false;
    in-out property <int>     auto-save-interval: 24;
    in-out property <string>  external-backup-path;
    in-out property <string>  application-version;
    in-out property <string>  edit-profile-name;
    in-out property <bool>    edit-profile-remote;

    // ── Callbacks ────────────────────────────────────────────────────────────
    callback save-remote-url(string);
    callback create-profile(string, bool);
    callback apply-profile(int);
    callback delete-profile(int);
    callback export-profile(int);
    callback import-profile(string);
    callback switch-desktop(int);
    callback toggle-backup-item(int, bool);
    callback toggle-conflict-fix(int, bool);
    callback add-folder-backup(string, string);
    callback remove-folder-backup(int);
    callback toggle-folder-backup(int, bool);
    callback run-folder-backup(int);
    callback toggle-scheduled-save(int, bool);
    callback run-now-scheduled-save(int);
    callback save-auto-save-settings(bool, int);
    callback save-external-backup-path(string);
    callback apply-conflict-fixes();
    callback refresh-all();
    callback edit-profile(int);
    callback save-edit-profile(string, string, bool);

    // ── Navigation state ─────────────────────────────────────────────────────
    in-out property <int>  nav-tab: 0;
    in-out property <bool> show-create-dialog: false;
    in-out property <bool> show-import-dialog: false;
    in-out property <bool> show-edit-dialog:   false;

    // ════════════════════════════════════════════════════════════════════════
    // Main Layout: Sidebar | Content
    // ════════════════════════════════════════════════════════════════════════
    HorizontalLayout {
        spacing: 0;

        // ── Sidebar ────────────────────────────────────────────────────────
        sidebar := Rectangle {
            width: 240px;
            background: #161b22;

            VerticalLayout {
                padding-top: 28px;
                padding-bottom: 20px;
                padding-left: 0px;
                padding-right: 0px;
                spacing: 2px;

                // Brand
                VerticalLayout {
                    padding-left: 24px;
                    padding-right: 24px;
                    padding-bottom: 8px;
                    spacing: 3px;
                    Text {
                        text: "SHAPESHIFTER";
                        font-size: 18px;
                        font-weight: 800;
                        color: #f97316;
                        letter-spacing: 1.5px;
                    }
                    Text {
                        text: "Desktop & Profile Manager";
                        font-size: 11px;
                        color: #8b949e;
                        wrap: no-wrap;
                    }
                }

                // Divider
                Rectangle {
                    height: 1px;
                    background: #30363d;
                    horizontal-stretch: 1;
                }

                Rectangle { height: 8px; }

                // ── Nav Items ───────────────────────────────────────────────
                // 0 · Profiles
                nav-item-0 := Rectangle {
                    height: 42px;
                    horizontal-stretch: 1;
                    background: root.nav-tab == 0
                        ? #f9731614
                        : (nav-touch-0.has-hover ? #ffffff0a : transparent);

                    // Left accent bar for active item
                    if root.nav-tab == 0: Rectangle {
                        width: 3px;
                        height: 28px;
                        background: #f97316;
                        border-radius: 2px;
                        x: 0px;
                        y: (parent.height - self.height) / 2;
                    }

                    nav-touch-0 := TouchArea {
                        clicked => { root.nav-tab = 0; }
                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 16px;
                            spacing: 10px;
                            alignment: start;
                            Text {
                                text: "Profiles";
                                font-size: 14px;
                                font-weight: root.nav-tab == 0 ? 700 : 500;
                                color: root.nav-tab == 0 ? #f97316 : #8b949e;
                                vertical-alignment: center;
                            }
                        }
                    }
                    animate background { duration: 120ms; }
                }

                // 1 · Desktop Switcher
                nav-item-1 := Rectangle {
                    height: 42px;
                    horizontal-stretch: 1;
                    background: root.nav-tab == 1
                        ? #f9731614
                        : (nav-touch-1.has-hover ? #ffffff0a : transparent);

                    if root.nav-tab == 1: Rectangle {
                        width: 3px;
                        height: 28px;
                        background: #f97316;
                        border-radius: 2px;
                        x: 0px;
                        y: (parent.height - self.height) / 2;
                    }

                    nav-touch-1 := TouchArea {
                        clicked => { root.nav-tab = 1; }
                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 16px;
                            alignment: start;
                            Text {
                                text: "Desktop Switcher";
                                font-size: 14px;
                                font-weight: root.nav-tab == 1 ? 700 : 500;
                                color: root.nav-tab == 1 ? #f97316 : #8b949e;
                                vertical-alignment: center;
                            }
                        }
                    }
                    animate background { duration: 120ms; }
                }

                // 2 · Backup Items
                nav-item-2 := Rectangle {
                    height: 42px;
                    horizontal-stretch: 1;
                    background: root.nav-tab == 2
                        ? #f9731614
                        : (nav-touch-2.has-hover ? #ffffff0a : transparent);

                    if root.nav-tab == 2: Rectangle {
                        width: 3px;
                        height: 28px;
                        background: #f97316;
                        border-radius: 2px;
                        x: 0px;
                        y: (parent.height - self.height) / 2;
                    }

                    nav-touch-2 := TouchArea {
                        clicked => { root.nav-tab = 2; }
                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 16px;
                            alignment: start;
                            Text {
                                text: "Backup Items";
                                font-size: 14px;
                                font-weight: root.nav-tab == 2 ? 700 : 500;
                                color: root.nav-tab == 2 ? #f97316 : #8b949e;
                                vertical-alignment: center;
                            }
                        }
                    }
                    animate background { duration: 120ms; }
                }

                // 3 · DE Conflict Fixes
                nav-item-3 := Rectangle {
                    height: 42px;
                    horizontal-stretch: 1;
                    background: root.nav-tab == 3
                        ? #f9731614
                        : (nav-touch-3.has-hover ? #ffffff0a : transparent);

                    if root.nav-tab == 3: Rectangle {
                        width: 3px;
                        height: 28px;
                        background: #f97316;
                        border-radius: 2px;
                        x: 0px;
                        y: (parent.height - self.height) / 2;
                    }

                    nav-touch-3 := TouchArea {
                        clicked => { root.nav-tab = 3; }
                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 16px;
                            alignment: start;
                            Text {
                                text: "DE Conflict Fixes";
                                font-size: 14px;
                                font-weight: root.nav-tab == 3 ? 700 : 500;
                                color: root.nav-tab == 3 ? #f97316 : #8b949e;
                                vertical-alignment: center;
                            }
                        }
                    }
                    animate background { duration: 120ms; }
                }

                // 4 · Folder Backup
                nav-item-4 := Rectangle {
                    height: 42px;
                    horizontal-stretch: 1;
                    background: root.nav-tab == 4
                        ? #f9731614
                        : (nav-touch-4.has-hover ? #ffffff0a : transparent);

                    if root.nav-tab == 4: Rectangle {
                        width: 3px;
                        height: 28px;
                        background: #f97316;
                        border-radius: 2px;
                        x: 0px;
                        y: (parent.height - self.height) / 2;
                    }

                    nav-touch-4 := TouchArea {
                        clicked => { root.nav-tab = 4; }
                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 16px;
                            alignment: start;
                            Text {
                                text: "Folder Backup";
                                font-size: 14px;
                                font-weight: root.nav-tab == 4 ? 700 : 500;
                                color: root.nav-tab == 4 ? #f97316 : #8b949e;
                                vertical-alignment: center;
                            }
                        }
                    }
                    animate background { duration: 120ms; }
                }

                // Spacer
                Rectangle { vertical-stretch: 1; }

                // Divider
                Rectangle {
                    height: 1px;
                    background: #30363d;
                    horizontal-stretch: 1;
                }

                // 5 · Settings
                nav-item-5 := Rectangle {
                    height: 42px;
                    horizontal-stretch: 1;
                    background: root.nav-tab == 5
                        ? #f9731614
                        : (nav-touch-5.has-hover ? #ffffff0a : transparent);

                    if root.nav-tab == 5: Rectangle {
                        width: 3px;
                        height: 28px;
                        background: #f97316;
                        border-radius: 2px;
                        x: 0px;
                        y: (parent.height - self.height) / 2;
                    }

                    nav-touch-5 := TouchArea {
                        clicked => { root.nav-tab = 5; }
                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 16px;
                            alignment: start;
                            Text {
                                text: "Settings";
                                font-size: 14px;
                                font-weight: root.nav-tab == 5 ? 700 : 500;
                                color: root.nav-tab == 5 ? #f97316 : #8b949e;
                                vertical-alignment: center;
                            }
                        }
                    }
                    animate background { duration: 120ms; }
                }

                // Divider
                Rectangle {
                    height: 1px;
                    background: #30363d;
                    horizontal-stretch: 1;
                }

                // Status footer
                VerticalLayout {
                    padding-left: 20px;
                    padding-right: 16px;
                    padding-top: 10px;
                    spacing: 4px;

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: #3fb950;
                            y: 3px;
                        }
                        Text {
                            text: root.current-de != "" ? root.current-de : "Unknown DE";
                            font-size: 11px;
                            color: #8b949e;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    Text {
                        text: "v" + root.application-version;
                        font-size: 10px;
                        color: #484f58;
                    }
                }
            }
        }

        // Thin vertical separator
        Rectangle {
            width: 1px;
            background: #21262d;
        }

        // ── Main content area ──────────────────────────────────────────────
        VerticalLayout {
            vertical-stretch: 1;
            spacing: 0;

            // Header bar
            header := Rectangle {
                height: 62px;
                background: #161b22;

                HorizontalLayout {
                    padding-left: 28px;
                    padding-right: 20px;
                    spacing: 12px;
                    alignment: center;

                    Text {
                        text: root.nav-tab == 0 ? "Profiles" :
                              root.nav-tab == 1 ? "Desktop Environments" :
                              root.nav-tab == 2 ? "Backup Items" :
                              root.nav-tab == 3 ? "DE Conflict Prevention" :
                              root.nav-tab == 4 ? "Folder Backup" : "Settings";
                        font-size: 20px;
                        font-weight: 700;
                        color: #f0f6fc;
                        vertical-alignment: center;
                    }

                    Rectangle { horizontal-stretch: 1; }

                    // Profiles header buttons
                    if root.nav-tab == 0: HorizontalLayout {
                        spacing: 8px;
                        SecondaryBtn {
                            label: "Import";
                            height: 36px;
                            clicked => { root.show-import-dialog = true; }
                        }
                        PrimaryBtn {
                            label: "+ New Profile";
                            height: 36px;
                            clicked => { root.show-create-dialog = true; }
                        }
                    }

                    // Desktop Switcher refresh button
                    if root.nav-tab == 1: SecondaryBtn {
                        label: "⟳  Refresh";
                        height: 36px;
                        clicked => { root.refresh-all(); }
                    }

                    // Conflict fixes apply button
                    if root.nav-tab == 3: PrimaryBtn {
                        label: "Apply Selected Fixes";
                        height: 36px;
                        clicked => { root.apply-conflict-fixes(); }
                    }
                }
            }

            // Thin underline separator
            Rectangle {
                height: 1px;
                background: #21262d;
            }

            // ── Scrollable content ─────────────────────────────────────────
            content-scroll := Rectangle {
                vertical-stretch: 1;
                background: #0d1117;
                clip: true;

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 24px;
                    spacing: 16px;

                    // ════════════════════════════════════════════
                    // TAB 0: Profiles
                    // ════════════════════════════════════════════
                    if root.nav-tab == 0: VerticalLayout {
                        vertical-stretch: 1;
                        spacing: 14px;

                        // Empty state
                        if profiles.length == 0: Rectangle {
                            height: 280px;
                            background: #161b22;
                            border-radius: 12px;

                            VerticalLayout {
                                alignment: center;
                                spacing: 14px;
                                padding: 24px;

                                Text {
                                    text: "No profiles yet";
                                    font-size: 18px;
                                    font-weight: 600;
                                    color: #8b949e;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Create a profile to capture your current desktop configuration,\ninstalled packages, and dotfiles.";
                                    font-size: 13px;
                                    color: #484f58;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                                HorizontalLayout {
                                    alignment: center;
                                    PrimaryBtn {
                                        label: "Create Your First Profile";
                                        height: 40px;
                                        clicked => { root.show-create-dialog = true; }
                                    }
                                }
                            }
                        }

                        // Profile list
                        for profile[index] in profiles: Rectangle {
                            height: 88px;
                            background: profile-hover.has-hover ? #1c2128 : #161b22;
                            border-radius: 10px;

                            profile-hover := TouchArea {
                                HorizontalLayout {
                                    padding: 18px;
                                    spacing: 14px;
                                    alignment: center;

                                    VerticalLayout {
                                        vertical-stretch: 1;
                                        spacing: 6px;
                                        alignment: center;

                                        HorizontalLayout {
                                            spacing: 8px;
                                            alignment: start;

                                            Text {
                                                text: profile.name;
                                                font-size: 15px;
                                                font-weight: 600;
                                                color: #f0f6fc;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }

                                            if profile.is-remote: Pill {
                                                label: "REMOTE";
                                                pill-bg: #f9731622;
                                                pill-color: #f97316;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 18px;
                                            alignment: start;
                                            Text {
                                                text: "Created " + profile.created;
                                                font-size: 11px;
                                                color: #484f58;
                                            }
                                            Text {
                                                text: "DE: " + profile.desktop;
                                                font-size: 11px;
                                                color: #484f58;
                                            }
                                            Text {
                                                text: profile.package-count + " pkgs";
                                                font-size: 11px;
                                                color: #484f58;
                                            }
                                            Text {
                                                text: profile.config-count + " configs";
                                                font-size: 11px;
                                                color: #484f58;
                                            }
                                        }
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: end;
                                        SmallBtn {
                                            label: "Edit";
                                            clicked => { root.edit-profile(index); }
                                        }
                                        SmallBtn {
                                            label: "Export";
                                            clicked => { root.export-profile(index); }
                                        }
                                        SmallBtn {
                                            label: "Delete";
                                            clicked => { root.delete-profile(index); }
                                        }
                                        SmallBtn {
                                            label: "Apply";
                                            is-primary: true;
                                            clicked => { root.apply-profile(index); }
                                        }
                                    }
                                }
                            }
                            animate background { duration: 120ms; }
                        }
                    }

                    // ════════════════════════════════════════════
                    // TAB 1: Desktop Switcher
                    // ════════════════════════════════════════════
                    if root.nav-tab == 1: VerticalLayout {
                        vertical-stretch: 1;
                        spacing: 14px;

                        // Info card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            height: 72px;
                            VerticalLayout {
                                padding: 16px;
                                spacing: 4px;
                                Text {
                                    text: "Switch between installed desktop environments";
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #c9d1d9;
                                }
                                Text {
                                    text: "Settings and packages are preserved. Switching requires a logout to take full effect.";
                                    font-size: 12px;
                                    color: #8b949e;
                                    wrap: word-wrap;
                                    overflow: elide;
                                }
                            }
                        }

                        // Empty state
                        if available-desktops.length == 0: Rectangle {
                            height: 160px;
                            background: #161b22;
                            border-radius: 10px;
                            VerticalLayout {
                                alignment: center;
                                padding: 24px;
                                Text {
                                    text: "No desktop environments detected.\nClick Refresh in the header to scan for installed DEs.";
                                    font-size: 13px;
                                    color: #8b949e;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // DE list
                        for de[index] in available-desktops: Rectangle {
                            height: 76px;
                            background: de-hover.has-hover ? #1c2128 : #161b22;
                            border-radius: 10px;

                            de-hover := TouchArea {
                                HorizontalLayout {
                                    padding: 18px;
                                    spacing: 14px;
                                    alignment: center;

                                    VerticalLayout {
                                        vertical-stretch: 1;
                                        spacing: 5px;
                                        alignment: center;

                                        HorizontalLayout {
                                            spacing: 10px;
                                            alignment: start;
                                            Text {
                                                text: de.name;
                                                font-size: 15px;
                                                font-weight: 600;
                                                color: #f0f6fc;
                                                vertical-alignment: center;
                                            }
                                            if de.is-current: Pill {
                                                label: "CURRENT";
                                                pill-bg: #23863633;
                                                pill-color: #3fb950;
                                            }
                                        }

                                        Text {
                                            text: de.is-current
                                                ? "Currently active desktop environment"
                                                : "Click Switch to set as default (requires logout)";
                                            font-size: 12px;
                                            color: #484f58;
                                        }
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    if !de.is-current: SmallBtn {
                                        label: "Switch";
                                        is-primary: true;
                                        clicked => { root.switch-desktop(index); }
                                    }
                                }
                            }
                            animate background { duration: 120ms; }
                        }
                    }

                    // ════════════════════════════════════════════
                    // TAB 2: Backup Items
                    // ════════════════════════════════════════════
                    if root.nav-tab == 2: VerticalLayout {
                        vertical-stretch: 1;
                        spacing: 14px;

                        // Info card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            height: 72px;
                            VerticalLayout {
                                padding: 16px;
                                spacing: 4px;
                                Text {
                                    text: "Select what to include in profile backups";
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #c9d1d9;
                                }
                                Text {
                                    text: "Toggle items on or off — these paths are archived when you create a new profile.";
                                    font-size: 12px;
                                    color: #8b949e;
                                    overflow: elide;
                                }
                            }
                        }

                        // Backup item list
                        for item[index] in backup-items: Rectangle {
                            height: 62px;
                            background: bi-hover.has-hover ? #1c2128 : #161b22;
                            border-radius: 8px;

                            bi-hover := TouchArea {
                                HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 18px;
                                    spacing: 14px;
                                    alignment: center;

                                    CheckBox {
                                        checked: item.enabled;
                                        toggled => { root.toggle-backup-item(index, self.checked); }
                                    }

                                    VerticalLayout {
                                        vertical-stretch: 1;
                                        spacing: 3px;
                                        alignment: center;
                                        Text {
                                            text: item.name;
                                            font-size: 13px;
                                            font-weight: 500;
                                            color: #f0f6fc;
                                        }
                                        Text {
                                            text: item.path;
                                            font-size: 11px;
                                            color: #484f58;
                                            overflow: elide;
                                        }
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    Pill {
                                        label: item.category;
                                    }

                                    Text {
                                        text: item.size-estimate;
                                        font-size: 11px;
                                        color: #484f58;
                                        horizontal-alignment: right;
                                        vertical-alignment: center;
                                        min-width: 70px;
                                    }
                                }
                            }
                            animate background { duration: 120ms; }
                        }
                    }

                    // ════════════════════════════════════════════
                    // TAB 3: DE Conflict Fixes
                    // ════════════════════════════════════════════
                    if root.nav-tab == 3: VerticalLayout {
                        vertical-stretch: 1;
                        spacing: 14px;

                        // Info card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            height: 72px;
                            VerticalLayout {
                                padding: 16px;
                                spacing: 4px;
                                Text {
                                    text: "Prevent conflicts between multiple desktop environments";
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #c9d1d9;
                                }
                                Text {
                                    text: "Fixes icon, cursor, GTK theme isolation, scaling, dark mode, and menu clutter issues.";
                                    font-size: 12px;
                                    color: #8b949e;
                                    overflow: elide;
                                }
                            }
                        }

                        // Conflict fix list
                        for fix[index] in conflict-fixes: Rectangle {
                            height: 72px;
                            background: cf-hover.has-hover ? #1c2128 : #161b22;
                            border-radius: 8px;

                            cf-hover := TouchArea {
                                HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 18px;
                                    spacing: 14px;
                                    alignment: center;

                                    CheckBox {
                                        checked: fix.enabled;
                                        toggled => { root.toggle-conflict-fix(index, self.checked); }
                                    }

                                    VerticalLayout {
                                        vertical-stretch: 1;
                                        spacing: 4px;
                                        alignment: center;
                                        Text {
                                            text: fix.name;
                                            font-size: 13px;
                                            font-weight: 500;
                                            color: #f0f6fc;
                                        }
                                        Text {
                                            text: fix.description;
                                            font-size: 11px;
                                            color: #484f58;
                                            wrap: word-wrap;
                                            overflow: elide;
                                        }
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    Pill {
                                        label: fix.category;
                                    }
                                }
                            }
                            animate background { duration: 120ms; }
                        }
                    }

                    // ════════════════════════════════════════════
                    // TAB 4: Folder Backup
                    // ════════════════════════════════════════════
                    if root.nav-tab == 4: VerticalLayout {
                        vertical-stretch: 1;
                        spacing: 14px;

                        // Info card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            height: 72px;
                            VerticalLayout {
                                padding: 16px;
                                spacing: 4px;
                                Text {
                                    text: "Backup specific folders to external locations";
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #c9d1d9;
                                }
                                Text {
                                    text: "Copy important folders to external drives, network shares, or cloud-synced directories.";
                                    font-size: 12px;
                                    color: #8b949e;
                                    overflow: elide;
                                }
                            }
                        }

                        // Add-new row
                        Rectangle {
                            height: 56px;
                            background: #161b22;
                            border-radius: 8px;
                            HorizontalLayout {
                                padding: 10px;
                                spacing: 8px;
                                alignment: center;

                                fb-source := LineEdit {
                                    placeholder-text: "Source folder path…";
                                    vertical-stretch: 1;
                                }

                                fb-dest := LineEdit {
                                    placeholder-text: "Destination folder path…";
                                    vertical-stretch: 1;
                                }

                                PrimaryBtn {
                                    label: "+ Add";
                                    height: 36px;
                                    clicked => {
                                        if (fb-source.text != "" && fb-dest.text != "") {
                                            root.add-folder-backup(fb-source.text, fb-dest.text);
                                            fb-source.text = "";
                                            fb-dest.text = "";
                                        }
                                    }
                                }
                            }
                        }

                        // Empty state
                        if folder-backups.length == 0: Rectangle {
                            height: 100px;
                            background: #161b22;
                            border-radius: 8px;
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "No folder backup jobs yet. Add one above.";
                                    font-size: 13px;
                                    color: #484f58;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        // Folder backup list
                        for fb[index] in folder-backups: Rectangle {
                            height: 70px;
                            background: fb-hover.has-hover ? #1c2128 : #161b22;
                            border-radius: 8px;

                            fb-hover := TouchArea {
                                HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 18px;
                                    spacing: 14px;
                                    alignment: center;

                                    CheckBox {
                                        checked: fb.enabled;
                                        toggled => { root.toggle-folder-backup(index, self.checked); }
                                    }

                                    VerticalLayout {
                                        vertical-stretch: 1;
                                        spacing: 4px;
                                        alignment: center;
                                        Text {
                                            text: fb.label;
                                            font-size: 13px;
                                            font-weight: 500;
                                            color: #f0f6fc;
                                        }
                                        Text {
                                            text: fb.source-path + "  →  " + fb.dest-path;
                                            font-size: 11px;
                                            color: #484f58;
                                            overflow: elide;
                                        }
                                    }

                                    Rectangle { horizontal-stretch: 1; }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        SmallBtn {
                                            label: "Run";
                                            is-primary: true;
                                            clicked => { root.run-folder-backup(index); }
                                        }
                                        SmallBtn {
                                            label: "Remove";
                                            clicked => { root.remove-folder-backup(index); }
                                        }
                                    }
                                }
                            }
                            animate background { duration: 120ms; }
                        }
                    }

                    // ════════════════════════════════════════════
                    // TAB 5: Settings
                    // ════════════════════════════════════════════
                    if root.nav-tab == 5: VerticalLayout {
                        vertical-stretch: 1;
                        spacing: 16px;

                        // Remote Backup card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            VerticalLayout {
                                padding: 20px;
                                spacing: 12px;
                                Text {
                                    text: "Remote Backup";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: #f0f6fc;
                                }
                                Text {
                                    text: "Remote Target URL or Path";
                                    font-size: 12px;
                                    color: #8b949e;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    settings-remote-url := LineEdit {
                                        text: root.remote-url;
                                        placeholder-text: "https://backup.example.com/profiles  or  file:///mnt/backup";
                                        vertical-stretch: 1;
                                    }
                                    PrimaryBtn {
                                        label: "Save";
                                        height: 36px;
                                        clicked => { root.save-remote-url(settings-remote-url.text); }
                                    }
                                }
                            }
                        }

                        // Auto-save card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            VerticalLayout {
                                padding: 20px;
                                spacing: 14px;
                                Text {
                                    text: "Automatic Profile Saving";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: #f0f6fc;
                                }
                                HorizontalLayout {
                                    spacing: 16px;
                                    alignment: start;
                                    CheckBox {
                                        checked: root.auto-save-enabled;
                                        text: "Enable auto-save";
                                    }
                                    Text {
                                        text: "Every";
                                        font-size: 13px;
                                        color: #8b949e;
                                        vertical-alignment: center;
                                    }
                                    auto-save-hours := Slider {
                                        minimum: 1;
                                        maximum: 168;
                                        value: root.auto-save-interval;
                                        min-width: 140px;
                                    }
                                    Text {
                                        text: Math.round(auto-save-hours.value) + " hours";
                                        font-size: 13px;
                                        color: #c9d1d9;
                                        vertical-alignment: center;
                                        min-width: 60px;
                                    }
                                    PrimaryBtn {
                                        label: "Save";
                                        height: 36px;
                                        clicked => {
                                            root.save-auto-save-settings(
                                                root.auto-save-enabled,
                                                Math.round(auto-save-hours.value)
                                            );
                                        }
                                    }
                                }
                            }
                        }

                        // External Backup Location card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            VerticalLayout {
                                padding: 20px;
                                spacing: 12px;
                                Text {
                                    text: "External Backup Location";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: #f0f6fc;
                                }
                                Text {
                                    text: "Default destination for folder backup jobs";
                                    font-size: 12px;
                                    color: #8b949e;
                                }
                                HorizontalLayout {
                                    spacing: 8px;
                                    settings-ext-backup := LineEdit {
                                        text: root.external-backup-path;
                                        placeholder-text: "/mnt/external-drive/backups";
                                        vertical-stretch: 1;
                                    }
                                    PrimaryBtn {
                                        label: "Save";
                                        height: 36px;
                                        clicked => { root.save-external-backup-path(settings-ext-backup.text); }
                                    }
                                }
                            }
                        }

                        // Profile Storage card
                        Rectangle {
                            background: #161b22;
                            border-radius: 10px;
                            VerticalLayout {
                                padding: 20px;
                                spacing: 8px;
                                Text {
                                    text: "Profile Storage";
                                    font-size: 15px;
                                    font-weight: 700;
                                    color: #f0f6fc;
                                }
                                Text {
                                    text: "~/.config/shapeshifter/profiles";
                                    font-size: 13px;
                                    color: #8b949e;
                                    font-weight: 500;
                                }
                                Text {
                                    text: "Profiles are stored locally as JSON with associated config archives.";
                                    font-size: 12px;
                                    color: #484f58;
                                }
                            }
                        }
                    }

                    // ── Status Banner ──────────────────────────────────────
                    if root.status-message != "": Rectangle {
                        min-height: 44px;
                        background: root.status-type == "error"   ? #f8514918 :
                                    root.status-type == "success" ? #23863618 : #f9731618;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: root.status-type == "error"   ? #f8514944 :
                                      root.status-type == "success" ? #23863644 : #f9731644;

                        HorizontalLayout {
                            padding: 12px;
                            spacing: 10px;
                            alignment: center;
                            Text {
                                text: root.status-message;
                                color: root.status-type == "error"   ? #f85149 :
                                       root.status-type == "success" ? #3fb950 : #f97316;
                                font-size: 13px;
                                wrap: word-wrap;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // Modal: Create Profile
    // ════════════════════════════════════════════════════════════════════════
    if root.show-create-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000099;

        Rectangle {
            width: 480px;
            background: #161b22;
            border-radius: 12px;
            border-width: 1px;
            border-color: #30363d;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 28px;
                spacing: 20px;

                // Title row
                HorizontalLayout {
                    Text {
                        text: "Create New Profile";
                        font-size: 18px;
                        font-weight: 700;
                        color: #f0f6fc;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    SmallBtn {
                        label: "✕";
                        clicked => { root.show-create-dialog = false; }
                    }
                }

                Rectangle { height: 1px; background: #30363d; }

                // Name field
                VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "Profile Name";
                        font-size: 12px;
                        color: #8b949e;
                    }
                    create-profile-name := LineEdit {
                        placeholder-text: "e.g., My GNOME Setup";
                        height: 36px;
                    }
                }

                create-save-remote := CheckBox {
                    text: "Also save to remote backup target";
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    SecondaryBtn {
                        label: "Cancel";
                        height: 36px;
                        clicked => {
                            root.show-create-dialog = false;
                            create-profile-name.text = "";
                        }
                    }
                    PrimaryBtn {
                        label: "Create Profile";
                        height: 36px;
                        enabled-btn: create-profile-name.text != "";
                        clicked => {
                            root.create-profile(create-profile-name.text, create-save-remote.checked);
                            root.show-create-dialog = false;
                            create-profile-name.text = "";
                        }
                    }
                }
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // Modal: Import Profile
    // ════════════════════════════════════════════════════════════════════════
    if root.show-import-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000099;

        Rectangle {
            width: 480px;
            background: #161b22;
            border-radius: 12px;
            border-width: 1px;
            border-color: #30363d;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 28px;
                spacing: 20px;

                HorizontalLayout {
                    Text {
                        text: "Import Profile";
                        font-size: 18px;
                        font-weight: 700;
                        color: #f0f6fc;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    SmallBtn {
                        label: "✕";
                        clicked => { root.show-import-dialog = false; }
                    }
                }

                Rectangle { height: 1px; background: #30363d; }

                VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "Profile Archive Path (.tar.gz)";
                        font-size: 12px;
                        color: #8b949e;
                    }
                    import-path := LineEdit {
                        placeholder-text: "/path/to/profile.tar.gz";
                        height: 36px;
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    SecondaryBtn {
                        label: "Cancel";
                        height: 36px;
                        clicked => {
                            root.show-import-dialog = false;
                            import-path.text = "";
                        }
                    }
                    PrimaryBtn {
                        label: "Import";
                        height: 36px;
                        enabled-btn: import-path.text != "";
                        clicked => {
                            root.import-profile(import-path.text);
                            root.show-import-dialog = false;
                            import-path.text = "";
                        }
                    }
                }
            }
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // Modal: Edit Profile
    // ════════════════════════════════════════════════════════════════════════
    if root.show-edit-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000099;

        Rectangle {
            width: 480px;
            background: #161b22;
            border-radius: 12px;
            border-width: 1px;
            border-color: #30363d;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;

            VerticalLayout {
                padding: 28px;
                spacing: 20px;

                HorizontalLayout {
                    Text {
                        text: "Edit Profile";
                        font-size: 18px;
                        font-weight: 700;
                        color: #f0f6fc;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    SmallBtn {
                        label: "✕";
                        clicked => { root.show-edit-dialog = false; }
                    }
                }

                Rectangle { height: 1px; background: #30363d; }

                VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "Profile Name";
                        font-size: 12px;
                        color: #8b949e;
                    }
                    edit-profile-name-input := LineEdit {
                        text: root.edit-profile-name;
                        height: 36px;
                    }
                }

                edit-save-remote := CheckBox {
                    text: "Save to remote backup target";
                    checked: root.edit-profile-remote;
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    SecondaryBtn {
                        label: "Cancel";
                        height: 36px;
                        clicked => { root.show-edit-dialog = false; }
                    }
                    PrimaryBtn {
                        label: "Save Changes";
                        height: 36px;
                        enabled-btn: edit-profile-name-input.text != "";
                        clicked => {
                            root.save-edit-profile(
                                root.edit-profile-name,
                                edit-profile-name-input.text,
                                edit-save-remote.checked
                            );
                        }
                    }
                }
            }
        }
    }
}